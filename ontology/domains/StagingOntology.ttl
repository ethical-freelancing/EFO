<https://purl.org/cco/staging/SystemAccount>         owl:deprecated true ; rdfs:seeAlso cco:ent00000029 .
<https://purl.org/cco/staging/SuperuserAccount>      owl:deprecated true ; rdfs:seeAlso cco:ent00000030 .
